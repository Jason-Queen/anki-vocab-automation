# ================================================
# Anki Vocabulary Automation 配置文件
# ================================================
# 复制此文件为 config.env 并填入您的实际配置值

# ================================================
# Collins Dictionary API 配置
# ================================================
# Collins API 密钥（必需）
# 从 https://www.collinsdictionary.com/api 获取
COLLINS_API_KEY=your_collins_api_key_here

# ================================================
# LLM 配置（OpenAI兼容API）
# ================================================
# 支持所有OpenAI兼容的LLM服务
# 常用服务配置示例：

# OpenAI (示例配置)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-api-key
# LLM_MODEL_NAME=gpt-4o-mini

# LM Studio本地服务
# LLM_BASE_URL=http://localhost:1234
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=local-model

# Ollama本地服务
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=llama3

# Anthropic Claude
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-your-anthropic-key
# LLM_MODEL_NAME=claude-3-5-sonnet-20241022

# 默认配置 (OpenAI)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key-here
LLM_MODEL_NAME=gpt-4o-mini

# LLM超时时间（秒）
LLM_TIMEOUT=60

# 是否启用LLM作为备选方案
ENABLE_LLM_FALLBACK=true

# ================================================
# TTS音频生成配置
# ================================================
# 是否启用TTS音频生成（当没有真实音频时）
ENABLE_TTS_FALLBACK=true

# TTS服务提供商
# 可选值：google, microsoft, responsivevoice
TTS_SERVICE=google

# TTS语音类型
TTS_VOICE=en-US

# ================================================
# 数据源优先级设置
# ================================================
# 可选值：
# - collins_only: 仅使用Collins API
# - llm_only: 仅使用LLM
# - collins_first: 优先使用Collins API，失败时使用LLM
# - llm_first: 优先使用LLM，失败时使用Collins API
DATA_SOURCE_STRATEGY=collins_first

# ================================================
# LLM高级配置（可选）
# ================================================
# 自动检测模型能力
LLM_AUTO_DETECT_CAPABILITIES=true

# 强制thinking模式（true/false/留空=自动）
LLM_FORCE_THINKING_MODE=

# 自定义温度（0.0-1.0，留空=使用模型默认值）
LLM_CUSTOM_TEMPERATURE=

# 自定义最大token数（留空=使用模型默认值）
LLM_CUSTOM_MAX_TOKENS=

# ================================================
# Anki Connect 配置
# ================================================
ANKI_CONNECT_HOST=localhost
ANKI_CONNECT_PORT=8765

# ================================================
# Anki 设置
# ================================================
DECK_NAME=Vocabulary
MODEL_NAME=Vocabulary

# ================================================
# 其他设置
# ================================================
# API请求间隔（秒）
REQUEST_DELAY=1

# API请求超时（秒）
REQUEST_TIMEOUT=10

# 最大重试次数
MAX_RETRIES=3

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 用户代理
USER_AGENT=Anki-Vocabulary-Automation/2.0 