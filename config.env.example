# ================================================
# Anki Vocabulary Automation 配置文件
# ================================================
# 复制此文件为 config.env 并填入您的实际配置值

# ================================================
# Collins Dictionary API 配置
# ================================================
# Collins API 密钥（必需）
# 从 https://www.collinsdictionary.com/api 获取
COLLINS_API_KEY=your_collins_api_key_here

# ================================================
# LLM 配置
# ================================================
# LLM_PROVIDER 可选值:
# - auto: 根据 LLM_BASE_URL 自动判断，默认会把空配置当作 LM Studio 本地服务
# - openai: 官方 OpenAI SDK
# - anthropic: 官方 Anthropic SDK（Messages API）
# - lmstudio: LM Studio OpenAI 兼容接口，支持 Responses / Chat
# - ollama: Ollama OpenAI 兼容接口，支持 Responses / Chat
# - openai_compat: 其他第三方 OpenAI 兼容后端（默认按 Chat 兼容模式）
LLM_PROVIDER=auto

# LLM_API_MODE 可选值:
# - auto: Anthropic 走 Messages；其余 provider 会在运行时自动选择
#         gpt-oss => Responses API
#         其他模型 => Chat Completions + JSON Schema
# - responses: OpenAI 兼容 Responses API
# - chat: OpenAI 兼容 Chat Completions API
# - messages: Anthropic Messages API
LLM_API_MODE=auto

# 常用服务配置示例：

# OpenAI (示例配置)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_PROVIDER=openai
# LLM_API_MODE=chat
# LLM_API_KEY=sk-your-openai-api-key
# LLM_MODEL_NAME=gpt-4o-mini

# LM Studio本地服务（推荐：自动路由）
# LLM_BASE_URL=http://localhost:1234
# LLM_PROVIDER=lmstudio
# LLM_API_MODE=auto
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=qwen/qwen3.5-9b

# LM Studio本地服务（显式 Chat API）
# LLM_BASE_URL=http://localhost:1234
# LLM_PROVIDER=lmstudio
# LLM_API_MODE=chat
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=qwen/qwen3.5-9b

# LM Studio本地服务（显式 gpt-oss Responses API）
# LLM_BASE_URL=http://localhost:1234
# LLM_PROVIDER=lmstudio
# LLM_API_MODE=responses
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=openai/gpt-oss-20b

# Ollama本地服务（推荐：自动路由）
# LLM_BASE_URL=http://localhost:11434
# LLM_PROVIDER=ollama
# LLM_API_MODE=auto
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=llama3

# Ollama本地服务（Chat API）
# LLM_BASE_URL=http://localhost:11434
# LLM_PROVIDER=ollama
# LLM_API_MODE=chat
# LLM_API_KEY=not-needed
# LLM_MODEL_NAME=llama3

# Anthropic Claude
# LLM_BASE_URL=https://api.anthropic.com
# LLM_PROVIDER=anthropic
# LLM_API_MODE=messages
# LLM_API_KEY=sk-ant-your-anthropic-key
# LLM_MODEL_NAME=claude-3-5-sonnet-20241022

# 第三方 OpenAI 兼容后端（默认 Chat 模式）
# LLM_BASE_URL=https://your-provider.example.com
# LLM_PROVIDER=openai_compat
# LLM_API_MODE=chat
# LLM_API_KEY=your-provider-key
# LLM_MODEL_NAME=your-model-name

# 默认配置 (LM Studio 本地自动路由)
LLM_BASE_URL=http://localhost:1234
LLM_API_KEY=not-needed

# 模型名留空时：
# - 对于 LM Studio / Ollama，程序会自动使用当前已加载模型
# - 如果同时加载了多个模型，程序会要求你显式设置 LLM_MODEL_NAME
# - 如果当前没有已加载模型，程序会报错并停止生成
# - 对于 OpenAI / Anthropic / 第三方 openai_compat，仍然需要显式填写模型名
LLM_MODEL_NAME=

# LLM超时时间（秒）
LLM_TIMEOUT=60

# GPT-OSS Responses API 思考强度
# 可选值: minimal, low, medium, high
# 留空时默认使用 medium
LLM_GPT_OSS_REASONING_EFFORT=medium

# LLM Prompt 版本
# - revised: 默认，优先使用用户原句判断词义和词性，适合直接贴入 “单词｜原句”
# - baseline: 较旧的兼容提示词
LLM_PROMPT_VERSION=revised

# 是否启用LLM作为备选方案
ENABLE_LLM_FALLBACK=true

# ================================================
# TTS音频生成配置
# ================================================
# 是否启用TTS音频生成（当没有真实音频时）
ENABLE_TTS_FALLBACK=true

# 兼容层 TTS 服务提供商（可选）
# 可选值：google, microsoft, responsivevoice
#
# 音频回退优先级说明：
# - 如果配置了 TTS_OPENAI_COMPAT_BASE_URL，程序会优先尝试本地/远程 openai_compat TTS
# - TTS_SERVICE 现在只表示“可选 legacy URL 兼容后备”
# - 留空表示不启用 legacy URL 回退
# - 卡片背面会显示音频来源，区分 Dictionary 和 TTS
#
# 兼容旧配置：如果你仍然写 TTS_SERVICE=openai_compat，也能工作，
# 但现在更推荐直接配置下面的 TTS_OPENAI_COMPAT_* 字段。
TTS_SERVICE=

# 传统URL式TTS语音类型
TTS_VOICE=en-US

# OpenAI兼容TTS服务（推荐主路径）
# 本地 Qwen3-TTS 示例：
# TTS_OPENAI_COMPAT_BASE_URL=http://127.0.0.1:8000
# TTS_OPENAI_COMPAT_API_KEY=not-needed
# TTS_OPENAI_COMPAT_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-VoiceDesign-bf16
# TTS_OPENAI_COMPAT_RESPONSE_FORMAT=wav
#
# 如果使用 CustomVoice 模型，还需要配置内置说话人，例如：
# TTS_OPENAI_COMPAT_VOICE=Ryan
#
# 如果不显式指定模型，程序会先读取 /health 里的 default_model。
# 默认会根据 en-GB / en-US 自动生成英式/美式口音指令；
# 也可以用下面的字段覆盖：
TTS_OPENAI_COMPAT_BASE_URL=
TTS_OPENAI_COMPAT_API_KEY=not-needed
TTS_OPENAI_COMPAT_MODEL=
TTS_OPENAI_COMPAT_VOICE=
TTS_OPENAI_COMPAT_INSTRUCTIONS=
TTS_OPENAI_COMPAT_RESPONSE_FORMAT=wav
TTS_OPENAI_COMPAT_TIMEOUT=60

# ================================================
# 数据源优先级设置
# ================================================
# 可选值：
# - collins_only: 仅使用Collins API
# - llm_only: 仅使用LLM
# - collins_first: 优先使用Collins API，失败时使用LLM
# - llm_first: 优先使用LLM，失败时使用Collins API
#
# 说明：
# - 这里控制的是“词卡内容”的来源顺序，不是音频来源顺序
# - 单词音频只有在当前卡片缺少音频时，才会触发上面的 TTS 回退链
DATA_SOURCE_STRATEGY=collins_first

# ================================================
# LLM生成配置（可选）
# ================================================
# 自定义温度（0.0-1.0，留空=使用默认值）
LLM_CUSTOM_TEMPERATURE=

# 自定义最大输出token数（留空=使用默认值）
LLM_CUSTOM_MAX_TOKENS=

# ================================================
# Anki Connect 配置
# ================================================
ANKI_CONNECT_HOST=localhost
ANKI_CONNECT_PORT=8765

# ================================================
# Anki 设置
# ================================================
DECK_NAME=Vocabulary
MODEL_NAME=Vocabulary

# ================================================
# 本地 Anki 验收测试（可选，默认不运行）
# ================================================
# 保持 false，避免常规 pytest 意外连到真人 Anki。
ANKI_LOCAL_TEST_RUN=false

# 运行本地验收时，要求当前打开的 Anki 测试账户名称。
ANKI_LOCAL_TEST_PROFILE=Anki Test

# 本地验收会在这个专用牌组里清空旧样例并重新导入 1 张卡。
ANKI_LOCAL_TEST_DECK=Vocabulary_LocalSmoke

# 建议使用简单词元，减少词形还原导致的观察噪音。
ANKI_LOCAL_TEST_WORD=clarify

# 可选：提供用户原句，验证正面 Example 与背面 GeneratedExample 的分离行为。
# ANKI_LOCAL_TEST_SOURCE_EXAMPLE=I asked the teacher to clarify the lesson.

# 可选：本地验收结果快照输出路径
# ANKI_LOCAL_TEST_ARTIFACT=tests/.artifacts/local_anki_import_latest.json

# ================================================
# 其他设置
# ================================================
# API请求间隔（秒）
REQUEST_DELAY=1

# API请求超时（秒）
REQUEST_TIMEOUT=10

# 最大重试次数
MAX_RETRIES=3

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 用户代理
USER_AGENT=Anki-Vocabulary-Automation/2.0
